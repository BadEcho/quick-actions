<Project Sdk="WixToolset.Sdk/6.0.2">
    <PropertyGroup>
        <OutputType>Bundle</OutputType>
        <DebugType>full</DebugType>
        <OutputName>QuickActions</OutputName>
        <OutputPath>$(OutputPath)\setup</OutputPath>
        <SignOutput>true</SignOutput>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="WixToolset.BootstrapperApplications.wixext" Version="6.0.2" />
        <PackageReference Include="WixToolset.Util.wixext" Version="6.0.2" />
        <None Include="Theme.xml" />
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="..\installer\Installer.wixproj" />
    </ItemGroup>
    <Target Name="RestoreDotnetTools" BeforeTargets="_GenerateRestoreProjectSpec">
		<Message Text="Restoring dotnet tools" Importance="High" />
		<Exec Command="dotnet tool restore" />
	</Target>
	<Target Name="SignBundleEngine">
		<Message Importance="high" Text="SignBundleEngine: $(MSBuildThisFileDirectory)\@(SignBundleEngine)" />
		<Exec Command="dotnet sign code trusted-signing -tse https://cus.codesigning.azure.net/ -tscp BadEchoSigning-Cert -tsa BadEchoSigning -t http://timestamp.acs.microsoft.com $(MSBuildThisFileDirectory)\@(SignBundleEngine)" IgnoreExitCode="true" IgnoreStandardErrorWarningFormat="true"/>
	</Target>
	<Target Name="SignBundle">
		<Message Importance="high" Text="SignBundle: @(SignBundle)" />
		<Exec Command="dotnet sign code trusted-signing -tse https://cus.codesigning.azure.net/ -tscp BadEchoSigning-Cert -tsa BadEchoSigning -t http://timestamp.acs.microsoft.com $(MSBuildThisFileDirectory)\@(SignBundle)" IgnoreExitCode="true" IgnoreStandardErrorWarningFormat="true"/>
	</Target>
</Project>
<badEcho:View x:Class="BadEcho.QuickActions.Views.MappingView"
              x:ClassModifier="internal"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:badEcho="http://schemas.badecho.com/presentation/2022/02/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:local="clr-namespace:BadEcho.QuickActions"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:vm="clr-namespace:BadEcho.QuickActions.ViewModels"
              mc:Ignorable="d"
              d:DesignStyle="{StaticResource DesignTimeControlStyle}"
              d:DesignWidth="550"
              >
    <d:DesignProperties.DataContext>
        <vm:MappingViewModel KeysText="Ctrl + S">
            <vm:MappingViewModel.Actions>
                <local:ScriptAction Name="An Action" />
            </vm:MappingViewModel.Actions>
        </vm:MappingViewModel>
    </d:DesignProperties.DataContext>
    <badEcho:View.Resources>
        <badEcho:MultiBooleanConverter x:Key="BooleanOrConverter"
                                       Operation="Or"
                                       />
        <badEcho:ViewContextTemplateSelector x:Key="ContextSelector" />
    </badEcho:View.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.Style>
                <Style TargetType="{x:Type Grid}">
                    <Style.Triggers>
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <MultiBinding Converter="{StaticResource BooleanOrConverter}">
                                    <Binding ElementName="Keys"
                                             Path="(Validation.HasError)"
                                             />
                                    <Binding ElementName="Actions"
                                             Path="(Validation.HasError)"
                                             />
                                </MultiBinding>
                            </DataTrigger.Binding>
                            <DataTrigger.Setters>
                                <Setter Property="Margin" Value="{StaticResource VerticalSectionSpacing}" />
                            </DataTrigger.Setters>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition SharedSizeGroup="KeysColumn" Width="Auto" />
                <ColumnDefinition SharedSizeGroup="ActionsColumn" Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="Keys"
                     Style="{StaticResource KeysTextBoxStyle}"
                     GotFocus="HandleKeysGotFocus"
                     TextChanged="HandleKeysTextChanged"
                     Margin="0,0,16,0"
                     Grid.Column="0"
                     />

            <ComboBox x:Name="Actions"
                      ItemsSource="{Binding Actions}"
                      SelectedItem="{Binding SelectedAction, ValidatesOnNotifyDataErrors=True}"
                      Validation.ErrorTemplate="{StaticResource ErrorTextBlockTemplate}"
                      Margin="0,0,16,0"
                      Grid.Column="1"
                      d:SelectedIndex="0"
                      />

            <ComboBox ItemsSource="{Binding CompletionSounds}"
                      SelectedItem="{Binding SelectedCompletionSound}"
                      Margin="0,0,16,0"
                      Grid.Column="2"
                      d:SelectedIndex="0"
                      >
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   TextTrimming="CharacterEllipsis"
                                   />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Button Style="{StaticResource GarbageButtonStyle}"
                    Command="{Binding DeleteCommand}"
                    Grid.Column="3"
                    />
        </Grid>
        <UserControl BorderBrush="{StaticResource AccentFillColorSecondaryBrush}"
                     BorderThickness="2,0,0,0"
                     Content="{Binding ActionConfigurationViewModel}"
                     ContentTemplateSelector="{StaticResource ContextSelector}"
                     Grid.Row="1"
                     d:ContentTemplate="{StaticResource DesignTimeConfigurationTemplate}"
                     d:Margin="4,12,0,0"
                     d:Padding="12,6,0,3"
                     >
            <UserControl.Resources>
                <!--  A design-time data template used to help us visualize what hosting an action configuration view might look like.  -->
                <d:DataTemplate x:Key="DesignTimeConfigurationTemplate">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Style="{StaticResource HeaderTextBlockStyle}"
                                   Text="Additional Option"
                                   />
                        <TextBox Text="Yadda Yadda Yadda..." />
                    </StackPanel>
                </d:DataTemplate>
            </UserControl.Resources>
            <UserControl.Style>
                <Style TargetType="UserControl">
                    <Setter Property="Padding" Value="12,6,0,3" />
                    <Setter Property="Margin" Value="4,12,0,0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActionConfigurationViewModel}"
                                     Value="{x:Null}"
                                     >
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </UserControl.Style>
        </UserControl>
    </Grid>
</badEcho:View>

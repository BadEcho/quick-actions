<badEcho:View x:Class="BadEcho.QuickActions.Views.SettingsView"
              x:ClassModifier="internal"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:badEcho="http://schemas.badecho.com/presentation/2022/02/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:vm="clr-namespace:BadEcho.QuickActions.ViewModels"
              mc:Ignorable="d"
              d:DesignStyle="{StaticResource DesignTimeControlStyle}"
              >
    <d:DesignProperties.DataContext>
        <vm:SettingsViewModel ActionsEnabled="True"
                              KeysText="Ctrl + Q"
                              MinimizeToTrayOnClose="True"
                              StartMinimized="True"
                              />
    </d:DesignProperties.DataContext>
    <DockPanel>
        <StackPanel Orientation="Vertical"
                    DockPanel.Dock="Top"
                    >
            <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}"
                       Text="Settings"
                       Margin="{StaticResource HeaderVerticalSpacing}"
                       />
            <CheckBox IsChecked="{Binding StartMinimized}"
                      Margin="{StaticResource ControlVerticalSpacing}"
                      >
                <TextBlock Style="{StaticResource HeaderTextBlockStyle}"
                           Text="Start Quick Actions Minimized"
                           Margin="0"
                           />
            </CheckBox>
            <CheckBox IsChecked="{Binding MinimizeToTrayOnClose}"
                      Margin="{StaticResource ControlVerticalSpacing}"
                      >
                <TextBlock Style="{StaticResource HeaderTextBlockStyle}"
                           Text="Close Button Minimizes to Tray"
                           Margin="0"
                           />
            </CheckBox>

            <CheckBox IsChecked="{Binding ActionsEnabled}"
                      Margin="{StaticResource ControlVerticalSpacing}"
                      >
                <TextBlock Style="{StaticResource HeaderTextBlockStyle}"
                           Text="Actions Enabled"
                           Margin="0"
                           />
            </CheckBox>

            <Border BorderBrush="{StaticResource AccentFillColorSecondaryBrush}"
                    BorderThickness="2,0,0,0"
                    Margin="{StaticResource VerticalSectionSpacing}"
                    Padding="12,6,0,3"
                    >
                <StackPanel Orientation="Vertical">
                    <TextBlock Style="{StaticResource HeaderTextBlockStyle}"
                               Text="Command Prompt Shortcut"
                               />

                    <TextBox x:Name="Keys"
                             Style="{StaticResource KeysTextBoxStyle}"
                             GotFocus="HandleKeysGotFocus"
                             TextChanged="HandleKeysTextChanged"
                             />
                </StackPanel>
            </Border>
        </StackPanel>

        <Button Style="{StaticResource AccentButtonStyle}"
                Command="{Binding SaveCommand}"
                Content="Save"
                IsEnabled="{Binding IsDirty}"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                DockPanel.Dock="Bottom"
                />
    </DockPanel>
</badEcho:View>

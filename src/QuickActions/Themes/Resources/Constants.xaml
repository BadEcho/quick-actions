<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    >

    <!--  Spacing between similar controls.  -->
    <Thickness x:Key="ControlVerticalSpacing"
               Bottom="8"
               />

    <!--  Spacing between headers/labels and related controls.  -->
    <Thickness x:Key="HeaderVerticalSpacing"
               Bottom="12"
               />

    <!--  Spacing between controls grouped together in a list or similar type of layout.  -->
    <Thickness x:Key="ListVerticalSpacing"
               Bottom="16"
               />

    <!--  Spacing between content sections.  -->
    <Thickness x:Key="VerticalSectionSpacing"
               Bottom="24"
               />

</ResourceDictionary>
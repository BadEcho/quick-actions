<badEcho:View x:Class="BadEcho.QuickActions.SystemSettings.Views.MinimizeWindowsView"
              x:ClassModifier="internal"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:badEcho="http://schemas.badecho.com/presentation/2022/02/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:local="clr-namespace:BadEcho.QuickActions.SystemSettings"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              mc:Ignorable="d"
              d:DesignStyle="{StaticResource DesignTimeControlStyle}"
              >
    <d:DesignProperties.DataContext>
        <local:MinimizeWindowsConfiguration ProcessName="notepad" />
    </d:DesignProperties.DataContext>
    <StackPanel Orientation="Vertical">
        <TextBlock Style="{StaticResource HeaderTextBlockStyle}"
                   Text="Process Name (optional)"
                   />

        <TextBox Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}" />
    </StackPanel>
</badEcho:View>
